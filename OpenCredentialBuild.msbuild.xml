
<Project DefaultTargets="BuildAll" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
  </PropertyGroup>

  <ItemGroup>
    <CoreSolution Include="OpenCredential\src\OpenCredential-1.0.0.0.sln" />
    <CorePluginSolutions Include="Plugins\Core\**\*.sln" />
    <ContribPluginSolutions Include="Plugins\Contrib\**\*.sln" />
    <OutputDirectories Include="Plugins\bin;Plugins\Core\bin;Plugins\Contrib\bin;OpenCredential\src\bin;OpenCredential\src\build" />
  </ItemGroup>
  
  <!-- Build everything -->
  <Target Name="BuildAll" DependsOnTargets="BuildCore;BuildCorePlugins" />
  
  <!-- Build core OpenCredential -->
  <Target Name="BuildCore">
    <!-- Build 64 bit platform -->
    <MSBuild Projects="@(CoreSolution)" ContinueOnError="false"
             Properties="Configuration=$(Configuration);Platform=x64">
    </MSBuild>
    <!-- Build 32 bit platform -->
    <MSBuild Projects="@(CoreSolution)" ContinueOnError="false"
             Properties="Configuration=$(Configuration);Platform=Win32">
    </MSBuild>
  </Target>
  
  <!-- Build supported core plugins -->
  <Target Name="BuildCorePlugins">
    <MSBuild Projects="@(CorePluginSolutions)" ContinueOnError="false"
             Properties="Configuration=$(Configuration);Platform=Any CPU">
    </MSBuild>
  </Target>

  <!-- Optional build for contrib plugins that may require legacy frameworks -->
  <Target Name="BuildContribPlugins">
    <MSBuild Projects="@(ContribPluginSolutions)" ContinueOnError="false"
             Properties="Configuration=$(Configuration);Platform=Any CPU">
    </MSBuild>
  </Target>

  <!-- Clean up -->
  <Target Name="Clean">
    <MSBuild Projects="@(CoreSolution)" Targets="Clean" Properties="Configuration=$(Configuration);Platform=x64" />
    <MSBuild Projects="@(CoreSolution)" Targets="Clean" Properties="Configuration=$(Configuration);Platform=Win32" />
    <MSBuild Projects="@(CorePluginSolutions)" Targets="Clean" Properties="Configuration=$(Configuration);Platform=Any CPU" />
    <MSBuild Projects="@(ContribPluginSolutions)" Targets="Clean" Properties="Configuration=$(Configuration);Platform=Any CPU" ContinueOnError="WarnAndContinue" />
    <RemoveDir Directories="@(OutputDirectories)" />
  </Target>

</Project>
